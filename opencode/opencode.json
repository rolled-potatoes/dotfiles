{
  "mcp": {
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "oauth": {}
    },
    "figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "oauth": {}
    }
  },
  "plugin": ["@rolled-potatoes/opencode-mermaid"],
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "model": "github-copilot/claude-opus-4.6"
    },
    "build": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "dumm_action": {
      "model": "github-copilot/claude-haiku-4.5",
      "mode": "subagent",
      "description": "단순하게 주어진 작업을 수행"
    },
    "trand_action": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "mode": "subagent",
      "description": "트랜디한 자료를 기반으로 주어진 작업을 수행"
    },
    "explore": {
      "model": "github-copilot/claude-haiku-4.5",
      "mode": "subagent",
      "description": "코드베이스 탐색에 최적화된 빠른 읽기 전용 agent입니다. 파일을 수정할 수 없습니다. 패턴 기반 파일 탐색, 키워드 검색, 코드베이스 관련 질의 응답을 빠르게 처리할 때 사용하세요.",
      "permission":{
        "edit": "deny",
        "bash":"allow",
        "webfetch": "deny"
      },
      "temperature": 0.0
    }
  }
}
